# =================================
# BANCO DE DADOS (Turso)
# Para desenvolvimento local, não precisa preencher (usa arquivo local.db)
# Para produção (Netlify), crie uma conta em https://turso.tech
# =================================
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# =================================
# AUTENTICAÇÃO (NextAuth)
# Gere um segredo com: openssl rand -base64 32
# =================================
AUTH_SECRET=seu_segredo_aqui_gere_com_openssl_rand_base64_32

# =================================
# EMAIL (Resend)
# Crie uma conta em https://resend.com (free tier: 3000 emails/mês)
# Adicione e verifique seu domínio ou use o domínio resend.dev para testes
# =================================
RESEND_API_KEY=re_sua_chave_aqui
RESEND_FROM_EMAIL=noreply@resend.dev

# =================================
# URL DO SITE
# =================================
NEXTAUTH_URL=http://localhost:3000
